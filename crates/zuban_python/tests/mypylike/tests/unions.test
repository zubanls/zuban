def foo(model: KnownModelName | str):
    if isinstance(model, str):
        reveal_type(model)  # N: Revealed type is "str"
    else:
        reveal_type(model)  # E: Statement is unreachable

    if model == "010":
        reveal_type(model)  # N: Revealed type is "Literal['010']?"

def bar(model: KnownModelName | int):
    if model == "010":
        reveal_type(model)  # N: Revealed type is "Literal['010']"

    if not isinstance(model, str):
        reveal_type(model)  # N: Revealed type is "int"

    if isinstance(model, int):
        reveal_type(model)  # N: Revealed type is "int"
    #else:
        #model + "asdf"
